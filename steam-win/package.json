{
  "name": "minefield-steam-win",
  "version": "0.0.1",
  "private": true,
  "description": "Steam Windows + Vite/React for MinefieldDirective",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:127.0.0.1:5173 && electron .\"",
    "build:renderer": "vite build",
    "start": "electron .",
    "start:dist": "cross-env NODE_ENV=production electron .",
    "build:win:dir": "vite build && electron-builder --dir --win",
    "lint": "tsc --noEmit -p tsconfig.json",
    "export-levels-json": "tsx scripts/export-levels-json.ts",
    "clean": "node -e \"try{require('fs').rmSync('release',{recursive:true,force:true});require('fs').rmSync('dist-renderer',{recursive:true,force:true})}catch(e){}\""
  },
  "dependencies": {
    "@fontsource/noto-sans-tc": "^5.2.9",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.6.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.19.3",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.minefielddirective.mineshell",
    "productName": "MinefieldDirective",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "dist-renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "executableName": "Game"
    }
  }
}
