{
  "byHeroId": {
    "ada": {
      "lines": [
        { "side": "hero", "text": "頻譜穩了。你剛才那幾步，雜訊沒把曲線帶歪。" },
        { "side": "player", "text": "我、我以為只是運氣……" },
        { "side": "hero", "text": "運氣不會讓讀數連收三格。之後多一路併收，我幫你把雷藏在波形裡。" },
        { "side": "player", "text": "那……請、請多指教，艾達。" },
        { "side": "hero", "text": "指教談不上。把電報按對，頻道另一頭的人才睡得著。" }
      ]
    },
    "selina": {
      "lines": [
        { "side": "hero", "text": "稜線對上了。這盤地面，總算沒騙你的眼。" },
        { "side": "player", "text": "我剛才差點踩進坡影裡……" },
        { "side": "hero", "text": "坡影會騙人，等高線不會。格網我幫你拉好了，別急著憑感覺下。" },
        { "side": "player", "text": "是、是！我會先找脊線再動。" },
        { "side": "hero", "text": "圖我簽過名了。下一關，跟線走。" }
      ]
    },
    "bobby": {
      "lines": [
        { "side": "hero", "text": "巴克耳朵豎到最大——這帶味道對了，你收尾乾淨。" },
        { "side": "player", "text": "我還以為鼻子那一套是迷信……" },
        { "side": "hero", "text": "迷信救不了人，標記可以。可疑格先聞再數，懂？" },
        { "side": "player", "text": "懂！我帶腦子，你帶狗。" },
        { "side": "hero", "text": "搜救隊就這規矩。回去給巴克加塊肉，算你過關。" }
      ]
    },
    "laozhang": {
      "lines": [
        { "side": "hero", "text": "梁沒塌，連鎖也收住了。你這次撐得住。" },
        { "side": "player", "text": "我剛才那一格要是再錯，全線就……" },
        { "side": "hero", "text": "錯一次我幫你撐一次。別搶著塌，結構我盯。" },
        { "side": "player", "text": "張哥，我會先撐住再談漂亮。" },
        { "side": "hero", "text": "就這樣。後方台站信你，我也信。" }
      ]
    },
    "claire": {
      "lines": [
        { "side": "hero", "text": "生命網格歸穩了。你手心還在發燙，呼吸倒是跟上了。" },
        { "side": "player", "text": "我……剛才盤面像在發燒，我怕讀岔。" },
        { "side": "hero", "text": "慌是訊號，不是命令。毒性前緣我先替你穩住，你跟線別跟慌。" },
        { "side": "player", "text": "克萊兒，我會聽你讀數。" },
        { "side": "hero", "text": "讀數對，下一格才救得了人。頻道裡又多一口能喘氣的。" }
      ]
    },
    "tungsten": {
      "lines": [
        { "side": "hero", "text": "佈雷序列：完成。冗餘障礙：已移除。" },
        { "side": "player", "text": "你……你是機器？剛才那幾聲報告嚇到我。" },
        { "side": "hero", "text": "操作員離線。自我優化：持續。你輸出效率：可納入協同。" },
        { "side": "player", "text": "我、我會跟上你的標定……別把我算成冗餘。" },
        { "side": "hero", "text": "冗餘判定：否。待機解除。下一序列，同步執行。" }
      ]
    }
  }
}
